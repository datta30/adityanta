# API Configuration
# Optional: if not set, app uses same-origin '/api/v1' (recommended with reverse proxy)
# VITE_API_BASE_URL=https://api.yourdomain.com/api/v1

# Optional: public frontend base URL for generated share links
# If not set, app uses current browser origin
# VITE_FRONTEND_BASE_URL=https://app.yourdomain.com

# Firebase Configuration (REQUIRED for Google Sign-In)
# Get these from Firebase Console > Project Settings > General > Your apps > SDK setup and configuration
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# Razorpay Configuration (for payments - handled by backend)
# VITE_RAZORPAY_KEY_ID=your_razorpay_key_id_here

# Environment
NODE_ENV=development
